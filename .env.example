# ============================================================================
# SEC-C Framework — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load it:
#   Linux/macOS:  export $(cat .env | xargs)
#   PowerShell:   Get-Content .env | ForEach-Object { if ($_ -match '^([^#].+?)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }
#   Git Bash:     set -a; source .env; set +a
# ============================================================================

# --------------------------------------------------------------------------
# LLM Provider Selection (Stage 3: Dual-Agent Validation)
# --------------------------------------------------------------------------
# Choose your LLM provider: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# Override the model for ANY provider (applies to both attacker + defender)
# Gemini models:  gemini-2.5-flash, gemini-2.5-flash-lite
# Groq models:    llama-3.3-70b-versatile, llama-3.1-8b-instant,
#                 qwen/qwen3-32b, meta-llama/llama-4-scout-17b-16e-instruct
# LLM_MODEL=gemini-2.5-flash

# --------------------------------------------------------------------------
# Gemini API
# --------------------------------------------------------------------------
# Get free key from: https://aistudio.google.com/apikey
# Free tier (March 2026):
#   Flash:      10 RPM / 250 RPD
#   Flash-Lite: 15 RPM / 1000 RPD
#   Pro:        NOT available on free tier (removed Dec 2025)
GEMINI_API_KEY=AIza...your-key-here

# Multiple keys for round-robin rotation (comma-separated)
# Each key gets independent rate limits -- 3 keys = 3x throughput
# GEMINI_API_KEYS=AIza...key1,AIza...key2,AIza...key3

# --------------------------------------------------------------------------
# Groq API (Alternative -- faster inference, 1000 RPD free)
# --------------------------------------------------------------------------
# Get free key from: https://console.groq.com/keys
# Free tier: 30 RPM / 1000 RPD for Llama 3.3 70B
# No credit card required
# GROQ_API_KEY=gsk_...your-key-here

# Multiple keys for round-robin rotation (comma-separated)
# Same pattern as Gemini -- each key gets independent rate limits
# GROQ_API_KEYS=gsk_...key1,gsk_...key2,gsk_...key3

# --------------------------------------------------------------------------
# GitHub Token (Optional: GitHub repo scanning)
# --------------------------------------------------------------------------
# Generate at: https://github.com/settings/tokens
# Required scope: repo (read) — for downloading pre-built CodeQL databases
# GITHUB_TOKEN=ghp_...your-token-here

# --------------------------------------------------------------------------
# NVD API Key (Optional: faster CVE downloads for RAG)
# --------------------------------------------------------------------------
# Without key: 5 requests / 30 seconds
# With key:    50 requests / 30 seconds (10x faster)
# Get from: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=your-nvd-api-key-here

# --------------------------------------------------------------------------
# Tool Paths (Optional: if not in system PATH)
# --------------------------------------------------------------------------
# CODEQL_HOME=~/.sec-c/codeql
# JOERN_HOME=~/.sec-c/joern

# --------------------------------------------------------------------------
# GPU / Device Configuration
# --------------------------------------------------------------------------
# Force CPU even if CUDA is available (useful for debugging)
# SEC_C_DEVICE=cpu

# CUDA device index (if multiple GPUs)
# CUDA_VISIBLE_DEVICES=0

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR
# SEC_C_LOG_LEVEL=INFO
